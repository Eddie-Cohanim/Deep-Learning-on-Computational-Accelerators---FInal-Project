{
    "model": {
        "in_size": [3, 224, 224],
        "class_names": ["orange wine", "rose wine", "Sauvignon blanc", "Chardonnay", "Cabernet Sauvignon", "Pinot Noir", "Malbec"],
        "channels": [32, 32, 64, 64, 128, 128],
        "pool_every": 2,
        "hidden_dims": [512, 256],
        "activation": "relu",
        "use_batchnorm": true,
        "dropout_probability": 0.3,
        "conv_kernel_size": 3,
        "pooling_type": "max",
        "pool_kernel_size": 2,
        "image_normalization_mean": [0.485, 0.456, 0.406],
        "image_normalization_std": [0.229, 0.224, 0.225]
    },

    "training": {
        "num_epochs": 20,
        "batch_size": 32,
        "learning_rate": 0.001,
        "num_dataloader_workers": 0,
        "optimizer": "Adam",
        "loss_function": "CrossEntropyLoss"
    },

    "preprocessing": {
        "run_augmentation": true,
        "augmentation_rotation_max_degrees": 15.0,
        "augmentation_brightness_jitter": 0.2,
        "augmentation_contrast_jitter": 0.2,
        "augmentation_saturation_jitter": 0.2
    }
}
