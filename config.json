{
    "model": {
        "in_size": [3, 224, 224],
        "class_names": ["orange wine", "rose wine", "Sauvignon blanc", "Chardonnay", "Cabernet Sauvignon", "Pinot Noir", "Malbec"],
        "channels": [16, 32, 64, 64],
        "pool_every": 2,
        "hidden_dims": [256, 128],
        "activation": "relu",
        "use_batchnorm": true,
        "dropout_probability": 0.5,
        "conv_kernel_size": 3,
        "pooling_type": "max",
        "pool_kernel_size": 2,
        "image_normalization_mean": [0.485, 0.456, 0.406],
        "image_normalization_std": [0.229, 0.224, 0.225]
    },

    "training": {
        "num_epochs": 300,
        "batch_size": 16,
        "learning_rate": 0.0002,
        "num_dataloader_workers": 0,
        "optimizer": "AdamW",
        "weight_decay": 1e-4,
        "loss_function": "CrossEntropyLoss",
        "early_stopping_patience": 50
    },

    "preprocessing": {
        "run_augmentation": false,
        "augmentation_fraction": 0.5,
        "number_of_augmented_copies_per_image": 2,
        "augmentation_rotation_max_degrees": 15.0,
        "augmentation_brightness_jitter": 0.2,
        "augmentation_contrast_jitter": 0.2,
        "augmentation_saturation_jitter": 0.2
    }
}
